{
  "$schema": "https://vicinae.com/schemas/config.json",
  "close_on_focus_loss": true,
  "theme": {
    "light": {
      "name": "stylix"
    },
    "dark": {
      "name": "stylix"
    }
  },
  "launcher_window": {
    "opacity": 1
  },
  "providers": {
    "files": {
      "preferences": {
        "autoIndexing": true,
        "excludedIndexingPaths": [],
        "indexingPaths": [
          "/home/gf/project",
          "/home/gf/life",
          "/home/gf/image"
        ]
      }
    }
  }
}