{
  "$schema": "https://vicinae.com/schemas/config.json",
  "close_on_focus_loss": true,
  "search_files_in_root": true,
  "font": {
    "rendering": "qt",
    "normal": {
      "size": 11
    }
  },
  "theme": {
    "light": {
      "name": "stylix"
    },
    "dark": {
      "name": "stylix"
    }
  },
  "launcher_window": {
    "opacity": 1,
    "client_side_decorations": {
      "enabled": false
    },
    "compact_mode": {
      "enabled": true
    }
  },
  "providers": {
    "core": {
      "entrypoints": {
        "about": {
          "enabled": false
        },
        "open-config-file": {
          "enabled": false
        },
        "open-default-config": {
          "enabled": false
        },
        "sponsor": {
          "enabled": false
        },
        "store": {
          "enabled": false
        }
      }
    },
    "files": {
      "preferences": {
        "autoIndexing": true,
        "excludedIndexingPaths": [],
        "indexingPaths": [
          "/home/gf/project",
          "/home/gf/life",
          "/home/gf/image"
        ]
      }
    },
    "power": {
      "entrypoints": {
        "lock": {
          "alias": "lock"
        },
        "power-off": {
          "alias": "off"
        },
        "reboot": {
          "alias": "boot"
        },
        "sleep": {
          "alias": "sleep"
        }
      }
    },
    "raycast-compat": {
      "entrypoints": {
        "store": {
          "enabled": false
        }
      }
    }
  }
}