{
  "artifactReviewPolicy": "always-proceed",
  "enableTelemetry": false,
  "enableTerminalSandbox": true,
  "model": "Gemini 3.1 Pro (High)",
  "notifications": true,
  "permissions": {
    "allow": [
      "unsandboxed(nix develop)",
      "unsandboxed(nix build)",
      "unsandboxed(nix flake)",
      "unsandboxed(nix eval)",
      "unsandboxed(git diff)",
      "unsandboxed(git log)",
      "unsandboxed(cmake)",
      "unsandboxed(ninja)",
      "unsandboxed(make)"
    ]
  },
  "toolPermission": "proceed-in-sandbox"
}
