{
  "context": {
    "fileFiltering": {
      "respectGitIgnore": false
    }
  },
  "general": {
    "sessionRetention": {
      "enabled": true,
      "maxAge": "30d",
      "warningAcknowledged": true
    },
    "plan": {
      "directory": ""
    },
   "enableAutoUpdate": false
  },
  "ui": {
    "hideBanner": true,
    "showUserIdentity": false,
    "showShortcutsHint": false
  },
  "experimental": {
    "modelSteering": true
  },
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    }
  },
  "tools": {
    "allowed": [
      "glob",
      "grep_search",
      "list_directory",
      "read_file",
      "read_many_files",
      "get_internal_docs",
      "google_web_search"
    ]
  }
}
