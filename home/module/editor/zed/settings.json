{
  "agent": {
    "default_model": {
      "provider": "copilot_chat",
      "model": "gpt-5-mini",
      "enable_thinking": false,
      "effort": "high"
    },
    "favorite_models": [],
    "model_parameters": []
  },
  "agent_servers": {
    "pi-acp": {
      "type": "registry"
    },
    "opencode": {
      "type": "registry"
    },
    "kimi": {
      "type": "registry"
    },
    "goose": {
      "type": "registry"
    },
    "github-copilot-cli": {
      "type": "registry"
    },
    "gemini": {
      "type": "registry"
    }
  },
  "base_keymap": "VSCode",
  "vim_mode": false,
  "icon_theme": {
    "mode": "dark",
    "light": "Zed (Default)",
    "dark": "Zed (Default)"
  },
  "auto_install_extensions": {
    "dockerfile": true,
    "emmet": true,
    "harper": true,
    "html": true,
    "java": true,
    "kotlin": true,
    "lua": true,
    "make": true,
    "nix": true,
    "nu": true,
    "sql": true,
    "toml": true,
    "typst": true
  },
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "buffer_font_size": 16.0,
  "theme": "Base16 untitled",
  "ui_font_family": "Aileron",
  "ui_font_size": 16.0
}
