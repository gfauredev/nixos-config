{
  "base_keymap": "VSCode",
  "vim_mode": false,
  "icon_theme": {
    "mode": "dark",
    "light": "Zed (Default)",
    "dark": "Zed (Default)"
  },
  "auto_install_extensions": {
    "dockerfile": true,
    "emmet": true,
    "harper": true,
    "html": true,
    "java": true,
    "kotlin": true,
    "lua": true,
    "make": true,
    "nix": true,
    "nu": true,
    "sql": true,
    "toml": true,
    "typst": true
  },
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "buffer_font_size": 16.0,
  "theme": "Base16 untitled",
  "ui_font_family": "Aileron",
  "ui_font_size": 16.0
}
